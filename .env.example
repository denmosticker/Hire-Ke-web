# .gitignore
.env
.env.local

# SMTP settings for real email delivery
# Fill these in with your SMTP provider credentials (Gmail, Outlook, SendGrid, etc.)

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_SECURE=false

# Application
PORT=3000
JWT_SECRET=change-me

# If you use development logging
NODE_ENV=development

# Public URL used by payment callbacks in production
PUBLIC_URL=https://your-domain.example
FRONTEND_URL=http://localhost:3000

# EmailJS contact form
# The EmailJS template should define To Email in EmailJS, not in the frontend.
EMAILJS_SERVICE_ID=service_ID
EMAILJS_TEMPLATE_ID=template_ID
EMAILJS_PUBLIC_KEY=PK
# Optional, recommended by EmailJS for server-side sends.
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# Vite-style names are also supported by the server route if you prefer these.
VITE_EMAILJS_SERVICE_ID=service_ID
VITE_EMAILJS_TEMPLATE_ID=template_ID
VITE_EMAILJS_PUBLIC_KEY=PK

# Object storage. local keeps files in uploads/<bucket>/user-<id>/ for development.
# Future adapters can use supabase or s3 with the same profile/document route code.
STORAGE_PROVIDER=local

# Supabase Storage (when STORAGE_PROVIDER=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# S3-compatible storage (when STORAGE_PROVIDER=s3)
S3_ENDPOINT=https://s3.your-provider.example
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=hireke-uploads
S3_PUBLIC_URL=https://cdn.your-domain.example

# PalPlus M-Pesa STK Push (server-side only)
PALPLUS_STK_PUSH_URL=https://api.palplus.example/mpesa/stk-push
PALPLUS_API_KEY=your-palplus-api-key
PALPLUS_CLIENT_ID=your-palplus-client-id
PALPLUS_SECRET_KEY=your-palplus-secret
PALPLUS_CALLBACK_SECRET=your-palplus-callback-hmac-secret
PALPLUS_CALLBACK_URL=https://your-domain.example/api/payments/palplus/callback
PALPLUS_REQUIRE_SIGNATURE=true
PALPLUS_MOCK=true
PALPLUS_TIMEOUT_MS=20000

